# =============================================================================
# ENVIRONMENT CONFIGURATION
# =============================================================================
# Set to 'development' or 'production'
DJANGO_ENV=development

# Django Settings
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================
# Frontend URL - Update this for production (e.g., https://yourdomain.com)
FRONTEND_URL=http://localhost:3000

# =============================================================================
# DATABASE - MongoDB
# =============================================================================
# For MongoDB Atlas (cloud):
# MONGO_CONNECTION_STRING=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
# For local MongoDB:
# MONGO_CONNECTION_STRING=mongodb://localhost:27017/
MONGO_CONNECTION_STRING=mongodb://localhost:27017/
MONGO_DB=linkedin_db
MONGO_USERNAME=admin
MONGO_PASSWORD=your-password-here
MONGO_AUTH_SOURCE=admin

# =============================================================================
# CORS SETTINGS
# =============================================================================
# Add your frontend URLs here (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173

# =============================================================================
# OAUTH CONFIGURATION
# =============================================================================
# LinkedIn OAuth
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_SIGNIN_REDIRECT_URI=http://localhost:3000/auth/linkedin/signin/callback

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_SIGNIN_REDIRECT_URI=http://localhost:3000/auth/google/signin/callback

# =============================================================================
# AI SERVICES
# =============================================================================
# Google AI
GOOGLE_API_KEY=your-google-api-key
GOOGLE_MODEL=gemini-2.0-flash

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Hugging Face
HUGGINGFACE_API_KEY=your-huggingface-api-key

# Qdrant Vector Database
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com